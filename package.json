{
  "name": "hainan-dialect-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/admin"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:api": "mvn spring-boot:run -f apps/api/pom.xml",
    "dev:ai": "python -m uvicorn app.main:app --reload --app-dir apps/ai-service --port 8001",
    "build:web": "npm --workspace apps/web run build",
    "build:admin": "npm --workspace apps/admin run build"
  }
}

