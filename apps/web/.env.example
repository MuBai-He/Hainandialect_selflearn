# Copy this file to .env.local (or .env.development.local) and tweak as needed.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# Spring Boot gateway base URL (used by lib/session + api/client).
# Also reads legacy field; keep consistent with apps/api server.port (default 8080).
VITE_API_BASE_URL=http://localhost:8080

# Python FastAPI ai-service base URL (used by api/asr.js for speech recognition).
# Start the service with:
#   npm run dev:ai                                         # easiest
#   ./apps/ai-service/start.sh                             # with env-var overrides
#   python -m uvicorn app.main:app --app-dir apps/ai-service --port 8001 --reload
VITE_AI_SERVICE_URL=http://localhost:8001
